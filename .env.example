# ---------------------------------------------------------------------------
# PyTorch Inference Platform — environment configuration
# Copy to `.env` and adjust. Every service reads these via pydantic-settings.
# ---------------------------------------------------------------------------

# --- Shared infrastructure -------------------------------------------------
REDIS_URL=redis://redis:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_TRACES_EXPORTER=otlp
LOG_LEVEL=INFO
ENVIRONMENT=local

# --- API Gateway -----------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_API_KEYS=demo-key-staff,demo-key-ml         # comma-separated valid keys
GATEWAY_RATE_LIMIT_RPS=200                           # per-API-key token bucket rate
GATEWAY_RATE_LIMIT_BURST=400
GATEWAY_REQUEST_TIMEOUT_MS=2000                      # max time to wait for a result
GATEWAY_MAX_IMAGE_BYTES=5242880                      # 5 MiB upload cap
GATEWAY_CIRCUIT_FAIL_THRESHOLD=20
GATEWAY_CIRCUIT_RESET_SECONDS=10

# --- Scheduler / Dynamic batching -----------------------------------------
SCHEDULER_STRATEGY=priority                          # fifo | priority | weighted
MAX_BATCH_SIZE=32
MAX_WAIT_MS=10
SCHEDULER_QUEUE_MAXLEN=50000                         # backpressure: queue overflow cap
SCHEDULER_NUM_PRIORITY_LEVELS=3
# weights used only by the 'weighted' strategy (per priority level, high->low)
SCHEDULER_CLASS_WEIGHTS=8,3,1

# --- Inference Worker ------------------------------------------------------
WORKER_ID=worker-0
WORKER_CONCURRENCY=1                                 # parallel batch executions per worker
RUNTIME_BACKEND=stub                                 # stub | torch_eager | torchscript | onnx
DEVICE=cpu                                           # cpu | cuda
DEFAULT_MODEL=resnet                                 # logical model name
DEFAULT_MODEL_VERSION=v2
MODEL_ARTIFACT_DIR=/app/models/artifacts
MODEL_CACHE_SIZE=4                                   # number of (name,version) kept hot in LRU
ENABLE_MIXED_PRECISION=false
ENABLE_QUANTIZATION=false
WORKER_BATCH_TIMEOUT_MS=5000                         # max execution time per batch

# --- Metrics service -------------------------------------------------------
METRICS_HOST=0.0.0.0
METRICS_PORT=9000
